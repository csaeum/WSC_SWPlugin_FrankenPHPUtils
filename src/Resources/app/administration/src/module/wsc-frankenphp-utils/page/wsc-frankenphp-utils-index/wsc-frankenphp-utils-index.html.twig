{% block wsc_frankenphp_utils_index %}
<sw-page class="wsc-frankenphp-utils-index">

    {% block wsc_frankenphp_utils_index_smart_bar %}
    <template #smart-bar-header>
        <h2>{{ $tc('wsc-frankenphp-utils.title') }}</h2>
    </template>
    <template #smart-bar-actions>
        <sw-button
            variant="primary"
            :isLoading="isLoadingRestart"
            :disabled="isLoadingFullDeploy || isLoadingCacheRestart || isLoadingRestart || isLoadingCache || isLoadingTheme"
            @click="onRestartWorkers">
            <sw-icon name="regular-power-btn" small/>
            {{ $tc('wsc-frankenphp-utils.actions.signal') }}
        </sw-button>
        <sw-button
            variant="primary"
            :isLoading="isLoadingFullDeploy"
            :disabled="isLoadingFullDeploy || isLoadingCacheRestart || isLoadingRestart || isLoadingCache || isLoadingTheme"
            @click="onFullDeploy">
            <sw-icon name="regular-sync" small/>
            {{ $tc('wsc-frankenphp-utils.actions.fullDeploy') }}
        </sw-button>
    </template>
    {% endblock %}

    {% block wsc_frankenphp_utils_index_content %}
    <template #content>
        <sw-card-view>

            {% block wsc_frankenphp_utils_index_card_info %}
            <sw-alert variant="info">
                {{ $tc('wsc-frankenphp-utils.info') }}
            </sw-alert>
            {% endblock %}

            {% block wsc_frankenphp_utils_index_card_status %}
            <sw-card :title="$tc('wsc-frankenphp-utils.card.status.title')">
                <sw-alert
                    v-if="lastStatus"
                    :variant="lastStatus.success ? 'success' : 'error'">
                    <strong>{{ lastStatus.success ? $tc('wsc-frankenphp-utils.status.success') : $tc('wsc-frankenphp-utils.status.error') }}</strong>
                    <br>
                    {{ $tc('wsc-frankenphp-utils.status.action') }}: {{ getStatusActionLabel(lastStatus.action) }}
                    <br>
                    {{ $tc('wsc-frankenphp-utils.status.triggeredBy') }}: {{ lastStatus.triggeredBy }}
                    <br>
                    {{ $tc('wsc-frankenphp-utils.status.time') }}: {{ formatStatusTime(lastStatus.createdAt) }}
                    <template v-if="lastStatus.results">
                        <br>
                        {{ $tc('wsc-frankenphp-utils.status.results') }}: {{ formatResults(lastStatus.results) }}
                    </template>
                    <template v-if="lastStatus.error">
                        <br>
                        {{ $tc('wsc-frankenphp-utils.status.errorDetails') }}: {{ lastStatus.error }}
                    </template>
                </sw-alert>
                <sw-alert v-else variant="info">
                    {{ $tc('wsc-frankenphp-utils.status.empty') }}
                </sw-alert>
            </sw-card>
            {% endblock %}

            {% block wsc_frankenphp_utils_index_card_result %}
            <sw-alert
                v-if="lastResult"
                :variant="lastResult.success ? 'success' : 'error'"
                :closable="true"
                @close="lastResult = null">
                {{ lastResult.message }}
                <template v-if="lastResult.results">
                    <br>
                    <small>
                        {{ $tc('wsc-frankenphp-utils.results.cache') }}: {{ lastResult.results.cacheClear ? '✓' : '✗' }} &nbsp;|&nbsp;
                        <template v-if="lastResult.results.themeCompile !== undefined">
                            {{ $tc('wsc-frankenphp-utils.results.theme') }}: {{ lastResult.results.themeCompile ? '✓' : '✗' }} &nbsp;|&nbsp;
                        </template>
                        {{ $tc('wsc-frankenphp-utils.results.restart') }}: {{ lastResult.results.restart ? '✓' : '✗' }}
                    </small>
                </template>
            </sw-alert>
            {% endblock %}

            {% block wsc_frankenphp_utils_index_card_actions %}
            <sw-card :title="$tc('wsc-frankenphp-utils.card.actions.title')">
                <p class="wsc-frankenphp-utils__description">
                    {{ $tc('wsc-frankenphp-utils.card.actions.description') }}
                </p>
                <div class="wsc-frankenphp-utils__actions">

                    <div class="wsc-frankenphp-utils__action-item">
                        <sw-button
                            variant="primary"
                            size="small"
                            :isLoading="isLoadingCacheRestart"
                            :disabled="isLoadingCacheRestart || isLoadingFullDeploy || isLoadingCache || isLoadingRestart || isLoadingTheme"
                            @click="onClearCacheAndRestart">
                            <sw-icon name="regular-sync" small/>
                            {{ $tc('wsc-frankenphp-utils.actions.cacheRestart') }}
                        </sw-button>
                        <p class="wsc-frankenphp-utils__action-hint">
                            {{ $tc('wsc-frankenphp-utils.actions.cacheRestartHint') }}
                        </p>
                    </div>

                    <div class="wsc-frankenphp-utils__action-item">
                        <sw-button
                            variant="primary"
                            size="small"
                            :isLoading="isLoadingCache"
                            :disabled="isLoadingCache || isLoadingFullDeploy || isLoadingCacheRestart || isLoadingRestart || isLoadingTheme"
                            @click="onClearCache">
                            <sw-icon name="regular-sync" small/>
                            {{ $tc('wsc-frankenphp-utils.actions.cacheClear') }}
                        </sw-button>
                        <p class="wsc-frankenphp-utils__action-hint">
                            {{ $tc('wsc-frankenphp-utils.actions.cacheClearHint') }}
                        </p>
                    </div>

                    <div class="wsc-frankenphp-utils__action-item">
                        <sw-button
                            variant="primary"
                            size="small"
                            :isLoading="isLoadingTheme"
                            :disabled="isLoadingTheme || isLoadingFullDeploy || isLoadingCacheRestart || isLoadingRestart || isLoadingCache"
                            @click="onCompileTheme">
                            <sw-icon name="regular-palette" small/>
                            {{ $tc('wsc-frankenphp-utils.actions.themeCompile') }}
                        </sw-button>
                        <p class="wsc-frankenphp-utils__action-hint">
                            {{ $tc('wsc-frankenphp-utils.actions.themeCompileHint') }}
                        </p>
                    </div>

                    <div class="wsc-frankenphp-utils__action-item">
                        <sw-button
                            variant="primary"
                            size="small"
                            :isLoading="isLoadingRestart"
                            :disabled="isLoadingRestart || isLoadingFullDeploy || isLoadingCacheRestart || isLoadingCache || isLoadingTheme"
                            @click="onRestartWorkers">
                            <sw-icon name="regular-power-btn" small/>
                            {{ $tc('wsc-frankenphp-utils.actions.restart') }}
                        </sw-button>
                        <p class="wsc-frankenphp-utils__action-hint">
                            {{ $tc('wsc-frankenphp-utils.actions.restartHint') }}
                        </p>
                    </div>

                </div>
            </sw-card>
            {% endblock %}

        </sw-card-view>
    </template>
    {% endblock %}

</sw-page>
{% endblock %}
